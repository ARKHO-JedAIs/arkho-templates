# Copy to .env and fill with your environment's values.
# All values are public configuration (no secrets). Vite only exposes VITE_*.

# AWS region of the Cognito user pool, e.g. us-east-1
VITE_AWS_REGION=us-east-1

# Cognito user pool id, e.g. us-east-1_abc123
VITE_COGNITO_USER_POOL_ID=us-east-1_REPLACE_ME

# Cognito app client id (public, no client secret)
VITE_COGNITO_USER_POOL_CLIENT_ID=REPLACE_ME

# Optional: Cognito domain (reserved for future hosted/federation flows)
VITE_COGNITO_DOMAIN=

# Base URL of the backend API, e.g. https://api.example.com
VITE_API_BASE_URL=https://api.example.com
